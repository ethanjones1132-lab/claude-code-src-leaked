GPT_OSS_BRIDGE_HOST=0.0.0.0
GPT_OSS_BRIDGE_PORT=8787
GPT_OSS_BRIDGE_API_KEYS=replace-me

# OpenAI-compatible endpoint for the stronger model lane.
GPT_OSS_BASE_URL=http://127.0.0.1:8000/v1
GPT_OSS_API_KEY=
GPT_OSS_PRIMARY_MODEL=gpt-oss-120b

# Optional separate endpoint for the fast lane. Leave matching the primary lane
# if both models are hosted behind the same vLLM or gateway process.
GPT_OSS_FAST_BASE_URL=http://127.0.0.1:8000/v1
GPT_OSS_FAST_API_KEY=
GPT_OSS_FAST_MODEL=gpt-oss-20b

# The launcher usually points at this alias.
GPT_OSS_AUTO_MODEL_ALIAS=gpt-oss-auto

# Bridge behavior.
GPT_OSS_BRIDGE_REQUEST_TIMEOUT_SECONDS=300
GPT_OSS_BRIDGE_HEALTHCHECK_TIMEOUT_SECONDS=8
